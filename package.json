{
  "name": "gemini-proxy",
  "version": "1.0.0",
  "description": "A lightweight proxy server that provides a unified API interface for both Google's Gemini and OpenAI's GPT models",
  "main": "dist/index.js",
  "bin": {
    "gemini-proxy": "./bin/cli.js"
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "serve": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "test": "jest --passWithNoTests"
  },
  "keywords": [
    "gemini",
    "openai",
    "proxy",
    "api",
    "gpt",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.10.0",
    "dotenv": "^17.2.0",
    "fastify": "^5.4.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.15",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
